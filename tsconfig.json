{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"strict": true,
		"ignoreDeprecations": "6.0",
		"types": ["node", "jest"],
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		}
	},
	"include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.d.ts"],
	"exclude": ["node_modules", "supabase"]
}
