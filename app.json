{
  "expo": {
    "name": "Les Santes",
    "slug": "app",
    "scheme": "les-santes",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/ios-light.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon-light.png",
      "resizeMode": "contain",
      "backgroundColor": "#8A1A10",
      "dark": {
        "image": "./assets/splash-icon-dark.png",
        "backgroundColor": "#1a0a08"
      }
    },
    "ios": {
      "bundleIdentifier": "com.polgubau.lessantes",
      "supportsTablet": false,
      "icon": {
        "light": "./assets/ios-light.png",
        "dark": "./assets/ios-dark.png",
        "tinted": "./assets/ios-tinted.png"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "La app necessita la teva ubicació per mostrar-la al mapa del festival i filtrar actes propers.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.polgubau.lessantes",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "monochromeImage": "./assets/adaptive-icon-mono.png",
        "backgroundColor": "#8A1A10"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "dffc30d5-6870-47b8-979f-a842d6848eb5"
      }
    },
    "plugins": [
      "expo-router",
      "expo-system-ui",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "La app necessita la teva ubicació per mostrar-la al mapa del festival i filtrar actes propers."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "La app vol afegir actes del festival al teu calendari."
        }
      ],
      "expo-font",
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon-mono.png",
          "color": "#8A1A10",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "expo-quick-actions",
        {
          "iosActions": [
            {
              "id": "ara",
              "title": "Ara",
              "subtitle": "Actes en curs",
              "icon": "time",
              "params": { "href": "/(tabs)/ara" }
            },
            {
              "id": "agenda",
              "title": "Agenda",
              "subtitle": "Tots els actes",
              "icon": "date",
              "params": { "href": "/(tabs)/agenda" }
            },
            {
              "id": "mapa",
              "title": "Mapa",
              "subtitle": "Mapa del festival",
              "icon": "location",
              "params": { "href": "/(tabs)/mapa" }
            }
          ]
        }
      ]
    ],
    "owner": "polgubau"
  }
}
