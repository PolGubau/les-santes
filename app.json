{
	"expo": {
		"name": "Les Santes",
		"slug": "santes-live",
		"scheme": "santes-live",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/icon.png",
		"userInterfaceStyle": "light",
		"newArchEnabled": true,
		"splash": {
			"image": "./assets/splash-icon.png",
			"resizeMode": "contain",
			"backgroundColor": "#ffffff"
		},
		"ios": {
			"supportsTablet": true
		},
		"android": {
			"adaptiveIcon": {
				"foregroundImage": "./assets/adaptive-icon.png",
				"backgroundColor": "#ffffff"
			},
			"edgeToEdgeEnabled": true,
			"predictiveBackGestureEnabled": false
		},
		"web": {
			"bundler": "metro",
			"favicon": "./assets/favicon.png"
		},
		"extra": {
			"eas": {
				"projectId": "dffc30d5-6870-47b8-979f-a842d6848eb5"
			}
		},
		"plugins": ["expo-router"]
	}
}
