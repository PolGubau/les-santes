{
  "expo": {
    "name": "Les Santes",
    "slug": "app",
    "scheme": "les-santes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F5"
    },
    "ios": {
      "bundleIdentifier": "com.polgubau.lessantes",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "La app necessita la teva ubicació per mostrar-la al mapa del festival i filtrar actes propers.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.polgubau.lessantes",
      "versionCode": 1,
      "privacyPolicyUrl": "https://lessantes.polgubau.com/privacy",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF8F5"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "dffc30d5-6870-47b8-979f-a842d6848eb5"
      }
    },
    "plugins": [
      "expo-router",
      "expo-system-ui",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "La app necessita la teva ubicació per mostrar-la al mapa del festival i filtrar actes propers."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "La app vol afegir actes del festival al teu calendari."
        }
      ],
      "expo-font",
      "expo-asset"
    ],
    "owner": "polgubau"
  }
}
