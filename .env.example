# Supabase - obtén els valors a https://app.supabase.com → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Festival ID — identifica quin festival carrega l'app (multi-tenant)
# Cada build / perfil EAS pot tenir un valor diferent:
#   les-santes-2026, les-santes-2027, granollers-2027, ...
EXPO_PUBLIC_FESTIVAL_ID=les-santes-2026

# MapTiler — obtén la key gratis en https://cloud.maptiler.com
# Ha d'usar EXPO_PUBLIC_ perquè Metro la inlini en temps de build
EXPO_PUBLIC_MAPTILER_KEY=your-maptiler-key-here

# ── Seed script (mai al client, només servidor) ──────────────
# Usa la service role key, no l'anon key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Festival a sembrar (per defecte: les-santes-2026)
FESTIVAL_ID=les-santes-2026
FESTIVAL_NAME=Les Santes 2026
FESTIVAL_CITY=Mataró
FESTIVAL_YEAR=2026
FESTIVAL_START=2026-07-24
FESTIVAL_END=2026-07-29