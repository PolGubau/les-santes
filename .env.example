# Supabase - obtén els valors a https://app.supabase.com → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# MapTiler — obtén la key gratis en https://cloud.maptiler.com
# Ha d'usar EXPO_PUBLIC_ perquè Metro la inlini en temps de build
EXPO_PUBLIC_MAPTILER_KEY=your-maptiler-key-here

# Només per a migracions de BD (mai al client)
SUPABASE_PASSWORD=...